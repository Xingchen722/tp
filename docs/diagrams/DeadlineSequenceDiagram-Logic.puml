@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":DeadlineCommandParser" as DeadlineCommandParser LOGIC_COLOR
participant "d:DeadlineCommand" as DeadlineCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

box Storage STORAGE_COLOR_T1
participant ":Storage" as Storage STORAGE_COLOR
end box

[-> LogicManager : execute("deadline ...")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("deadline ...")
activate AddressBookParser

create DeadlineCommandParser
AddressBookParser -> DeadlineCommandParser
activate DeadlineCommandParser

AddressBookParser -> DeadlineCommandParser : parse(...)
create DeadlineCommand
DeadlineCommandParser -> DeadlineCommand
DeadlineCommandParser --> AddressBookParser : d
deactivate DeadlineCommandParser
destroy DeadlineCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> DeadlineCommand : execute(m)
activate DeadlineCommand
DeadlineCommand -> Model : getFilteredApplicationList()
DeadlineCommand -> Model : setApplication(... with new deadline)
DeadlineCommand -> Model : commitAddressBook()

create CommandResult
DeadlineCommand -> CommandResult
DeadlineCommand --> LogicManager : r
deactivate DeadlineCommand

LogicManager -> Model : getAddressBook()
activate Model
Model --> LogicManager : addressBook
deactivate Model

LogicManager -> Storage : saveAddressBook(addressBook)
activate Storage
Storage --> LogicManager
deactivate Storage

[<-- LogicManager
deactivate LogicManager
@enduml
