@startuml
!include style.puml

title Interactions Inside the Logic Component for the `findnote` Command

skinparam ParticipantFontColor black
skinparam ParticipantBorderColor black
skinparam ParticipantBackgroundColor white
skinparam ActorFontColor black
skinparam ActorBorderColor black
skinparam ActorBackgroundColor white
skinparam SequenceLifeLineBorderColor black
skinparam SequenceLifeLineBackgroundColor white
skinparam ArrowColor black
skinparam NoteFontColor black
skinparam NoteBorderColor black
skinparam NoteBackgroundColor white
skinparam ResponseMessageBelowArrow true
skinparam maxMessageSize 80

actor User
participant ":LogicManager" as LogicManager
participant ":AddressBookParser" as AddressBookParser
participant ":FindNoteCommandParser" as FindNoteCommandParser
participant "c:FindNoteCommand" as FindNoteCommand
participant "p:NoteContainsKeywordsPredicate" as Predicate
participant "m:Model" as Model

User -> LogicManager : execute("findnote recruiter followup")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("findnote recruiter followup")
activate AddressBookParser

AddressBookParser -> FindNoteCommandParser : parse("recruiter followup")
activate FindNoteCommandParser

create Predicate
FindNoteCommandParser -> Predicate : create predicate
activate Predicate
Predicate --> FindNoteCommandParser
deactivate Predicate

create FindNoteCommand
FindNoteCommandParser -> FindNoteCommand : create command
activate FindNoteCommand
FindNoteCommand --> FindNoteCommandParser : c
deactivate FindNoteCommand

FindNoteCommandParser --> AddressBookParser : c
deactivate FindNoteCommandParser

AddressBookParser --> LogicManager : c
deactivate AddressBookParser

LogicManager -> FindNoteCommand : execute(m)
activate FindNoteCommand

FindNoteCommand -> Model : updateFilteredApplicationList(predicate)
activate Model
Model --> FindNoteCommand
deactivate Model

FindNoteCommand --> LogicManager : CommandResult
deactivate FindNoteCommand

LogicManager --> User : CommandResult
deactivate LogicManager
@enduml
